{
  "name": "trash-kit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @trash-kit/ui --filter @trash-kit/common --filter @trash-kit/auth dev",
    "build": "pnpm --parallel --filter @trash-kit/ui --filter @trash-kit/common --filter @trash-kit/auth build",
    "release": "semantic-release",
    "release:ui": "cd packages/ui && pnpm release",
    "release:common": "cd packages/common && pnpm release",
    "release:auth": "cd packages/auth && pnpm release",
    "release:all": "pnpm release:ui && pnpm release:common && pnpm release:auth"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.4",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "semantic-release": "^24.2.7",
    "typescript": "latest"
  }
}
